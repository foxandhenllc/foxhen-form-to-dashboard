{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "strict": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "outDir": ".smoke",
    "rootDir": "."
  },
  "include": ["src/data/**/*.ts", "src/exporters/**/*.ts", "src/lib/**/*.ts"]
}
